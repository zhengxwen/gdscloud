# Dynamically load the compiled C/C++ shared library
useDynLib(gdscloud,
    gdscloud_open_s3, gdscloud_open_gcs, gdscloud_open_azure,
    gdscloud_cache_clear, gdscloud_cache_info, gdscloud_list_streams)

# Import gdsfmt so its DLL are loaded first
import(gdsfmt)

# Export the following names
export(
    gdsCloudOpen,
    gdsCloudConfigS3,
    gdsCloudConfigGCS,
    gdsCloudConfigAzure,
    gdsCloudCacheSize,
    gdsCloudCacheClear,
    gdsCloudCacheInfo,
    gdsCloudList,
    gdsCloudSchemes
)
